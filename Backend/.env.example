# ─────────────────────────────────────────────
# TripiiTrip Backend — Environment Variables
# Copy this file to .env and fill in real values
# NEVER commit .env to version control
# ─────────────────────────────────────────────

# Server
PORT=8000
NODE_ENV=production

# MongoDB
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>

# JWT Secrets — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
ACCESS_TOKEN_SECRET=
REFRESH_TOKEN_SECRET=
ACCESS_TOKEN_EXPIRY=1d
REFRESH_TOKEN_EXPIRY=7d

# File upload limits
MAX_FILE_SIZE=20971520
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,application/pdf

# Cloudinary — https://console.cloudinary.com
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Gemini AI — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_API_KEY_FOR_OVERVIEW=
GEMINI_API_KEY_FOR_SAFETY=
AI_MODE=gemini

# News API — https://newsapi.org
NEWSAPI_API_KEY=

# Unsplash — https://unsplash.com/oauth/applications
UNSPLASH_ACCESS_KEY=
UNSPLASH_SECRET_KEY=

# SMTP (Brevo / SendGrid / Mailgun / etc.)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Redis (Upstash recommended for free tier) — used by BullMQ job queues
# Format: rediss://<user>:<password>@<host>:<port>
# Leave empty to disable job queues (server will still start)
REDIS_URL=

# Frontend origin for Socket.IO CORS (set to your Vercel deployment URL)
FRONTEND_URL=https://tripii-trip-black.vercel.app

# OTP — set to "false" in production to enforce email verification
DISABLE_OTP=false